import ReactMarkdown from "react-markdown";

interface MarkdownRendererProps {
  content: string;
}

export function MarkdownRenderer({ content }: MarkdownRendererProps) {
  // If content is empty, show a gentle placeholder
  if (!content || !content.trim()) {
    return (
      <div id="renderer-empty-state" className="flex h-full items-center justify-center text-gray-400 italic text-sm py-12 select-none">
        Start writing to see the preview...
      </div>
    );
  }

  return (
    <div id="markdown-rendered-content" className="prose-custom break-words">
      <ReactMarkdown
        components={{
          h1: ({ ...props }) => (
            <h1 id="md-h1" className="text-2xl sm:text-3xl font-bold text-slate-100 mt-6 mb-4 tracking-tight border-b border-[#2a2a2a] pb-3" {...props} />
          ),
          h2: ({ ...props }) => (
            <h2 id="md-h2" className="text-xl sm:text-2xl font-semibold text-slate-200 mt-5 mb-3 tracking-tight pb-1 border-b border-[#1e1e1e]" {...props} />
          ),
          h3: ({ ...props }) => (
            <h3 id="md-h3" className="text-lg sm:text-xl font-semibold text-slate-200 mt-4 mb-2" {...props} />
          ),
          h4: ({ ...props }) => (
            <h4 id="md-h4" className="text-base sm:text-lg font-semibold text-slate-300 mt-3 mb-2" {...props} />
          ),
          p: ({ ...props }) => (
            <p id="md-p" className="text-slate-300 leading-relaxed mb-4 text-sm sm:text-base" {...props} />
          ),
          ul: ({ ...props }) => (
            <ul id="md-ul" className="list-disc pl-6 mb-4 space-y-1.5 text-slate-300 text-sm sm:text-base" {...props} />
          ),
          ol: ({ ...props }) => (
            <ol id="md-ol" className="list-decimal pl-6 mb-4 space-y-1.5 text-slate-300 text-sm sm:text-base" {...props} />
          ),
          li: ({ ...props }) => (
            <li id="md-li" className="pl-1 text-slate-300" {...props} />
          ),
          blockquote: ({ ...props }) => (
            <blockquote id="md-blockquote" className="border-l-4 border-slate-600 bg-[#1c1c1c] pl-4 py-2 pr-2 rounded-r-lg my-4 italic text-slate-300 text-sm sm:text-base" {...props} />
          ),
          code: ({ className, children, ...props }) => {
            const isInline = !className;
            if (isInline) {
              return (
                <code id="md-inline-code" className="bg-[#2a2a2a] text-rose-400 font-mono text-xs px-1.5 py-0.5 rounded border border-[#3a3a3a]" {...props}>
                  {children}
                </code>
              );
            }
            return (
              <pre id="md-code-block-container" className="bg-[#121212] border border-[#2a2a2a] text-slate-100 font-mono text-xs sm:text-sm p-4 rounded-xl my-4 overflow-x-auto shadow-sm select-text">
                <code id="md-code-block" className={className} {...props}>
                  {children}
                </code>
              </pre>
            );
          },
          a: ({ ...props }) => (
            <a id="md-link" className="text-blue-400 hover:text-blue-300 underline underline-offset-2 transition-colors font-medium" target="_blank" rel="noopener noreferrer" {...props} />
          ),
          img: ({ ...props }) => (
            <img id="md-img" className="rounded-xl max-w-full h-auto my-6 border border-[#2a2a2a] shadow-sm" referrerPolicy="no-referrer" {...props} />
          ),
          hr: ({ ...props }) => (
            <hr id="md-hr" className="my-6 border-t border-[#2a2a2a]" {...props} />
          ),
          table: ({ ...props }) => (
            <div id="md-table-wrapper" className="my-6 overflow-x-auto rounded-lg border border-[#2a2a2a]">
              <table id="md-table" className="min-w-full border-collapse text-sm" {...props} />
            </div>
          ),
          thead: ({ ...props }) => (
            <thead id="md-thead" className="bg-[#181818] text-slate-200 font-medium" {...props} />
          ),
          tbody: ({ ...props }) => (
            <tbody id="md-tbody" className="divide-y divide-[#2a2a2a] text-slate-300" {...props} />
          ),
          tr: ({ ...props }) => (
            <tr id="md-tr" className="hover:bg-[#1e1e1e]/50 transition-colors" {...props} />
          ),
          th: ({ ...props }) => (
            <th id="md-th" className="px-4 py-2.5 text-left border-b border-[#2a2a2a] font-semibold" {...props} />
          ),
          td: ({ ...props }) => (
            <td id="md-td" className="px-4 py-2.5 border-b border-[#2a2a2a]" {...props} />
          ),
          input: ({ ...props }) => {
            if (props.type === "checkbox") {
              return (
                <input
                  id="md-checkbox"
                  type="checkbox"
                  disabled
                  className="rounded border-[#3a3a3a] bg-[#1a1a1a] text-blue-500 focus:ring-blue-500 h-4 w-4 mr-2 cursor-not-allowed align-middle"
                  {...props}
                />
              );
            }
            return <input {...props} />;
          }
        }}
      >
        {content}
      </ReactMarkdown>
    </div>
  );
}
